# Image coordinates. CI replaces tags with immutable commit SHAs.
BACKEND_IMAGE_REGISTRY=ghcr.io/zhifeimi
BACKEND_IMAGE_TAG=latest

# Cloudflare Tunnel on this host connects to the loopback gateway. Use a
# specific LAN address only when cloudflared runs on a different trusted node.
API_BIND_ADDRESS=127.0.0.1
API_PORT=8080
PUBLIC_BASE_URL=https://dentist.example.com

# Generate independent, URL-safe values; do not reuse these examples.
POSTGRES_PASSWORD=replace-with-a-long-random-value
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-different-long-random-value
SPRING_CONFIG_USER=config-client
SPRING_CONFIG_PASS=replace-with-a-different-long-random-value

# Redis backs session/revocation state and rate limiting; every service
# authenticates with the same password. Override REDIS_HOST/REDIS_PORT only
# when Redis runs outside this Compose project.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-a-different-long-random-value

# HMAC key for anonymous session fingerprints (api-gateway).
ANONYMOUS_SESSION_FINGERPRINT_KEY=replace-with-a-different-long-random-value

# Pepper mixed into email verification code hashes (auth-service).
EMAIL_VERIFICATION_CODE_PEPPER=replace-with-a-different-long-random-value

# PKCS#8 private key and X.509 public key, each as a single Base64 line.
JWT_RSA_PRIVATE_KEY=replace-with-base64-pkcs8-private-key
JWT_RSA_PUBLIC_KEY=replace-with-base64-x509-public-key
JWT_RSA_KEY_ID=dentistdss-homelab-1

# Service-to-service credentials (optional). Each issuing service signs its own
# short-lived RS256 credential for authenticated backend-to-backend calls; the
# target service verifies it with the issuer's public key. Leave the private
# keys empty to keep the credential interceptors dormant — target endpoints
# then reject uncredentialed calls, exactly as before this hardening. Keys are
# single-line PEM: PKCS#8 private, X.509 public. Each issuer needs an
# independent RSA pair and a unique key ID; do not reuse the JWT keys.
# Issuer private keys (supplied only to the issuing service):
AUTH_SERVICE_AUTH_PRIVATE_KEY=
APPOINTMENT_SERVICE_AUTH_PRIVATE_KEY=
CLINICAL_RECORDS_SERVICE_AUTH_PRIVATE_KEY=
NOTIFICATION_SERVICE_AUTH_PRIVATE_KEY=
# Issuer key IDs (must be unique across issuers):
AUTH_SERVICE_AUTH_KEY_ID=auth-service-1
APPOINTMENT_SERVICE_AUTH_KEY_ID=appointment-service-1
CLINICAL_RECORDS_SERVICE_AUTH_KEY_ID=clinical-records-service-1
NOTIFICATION_SERVICE_AUTH_KEY_ID=notification-service-1
# Issuer public keys shared with trusting targets:
#   _AUTH           trusted by audit-service and notification-service
#   _APPOINTMENT    trusted by notification-service
#   _CLINICALRECORDS trusted by notification-service
#   _NOTIFICATION   trusted by user-profile-service
SERVICE_AUTH_PUBLIC_KEY_AUTH=
SERVICE_AUTH_PUBLIC_KEY_APPOINTMENT=
SERVICE_AUTH_PUBLIC_KEY_CLINICALRECORDS=
SERVICE_AUTH_PUBLIC_KEY_NOTIFICATION=
SERVICE_AUTH_KEY_ID_AUTH=auth-service-1
SERVICE_AUTH_KEY_ID_APPOINTMENT=appointment-service-1
SERVICE_AUTH_KEY_ID_CLINICALRECORDS=clinical-records-service-1
SERVICE_AUTH_KEY_ID_NOTIFICATION=notification-service-1

# Google OAuth application.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# SMTP provider.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-user
MAIL_PASSWORD=replace-with-smtp-password

# Optional AI profile. Leave COMPOSE_PROFILES empty to deploy the core system
# without genai-service. To enable it, set COMPOSE_PROFILES=ai and provide a
# service-account JSON file at GCP_CREDENTIALS_PATH. Generate a separate RSA
# key pair for gateway-to-GenAI authentication; use a single-line PKCS#8 private
# key, X.509 public key, and unique rotation key ID. The private key is supplied
# only to api-gateway.
COMPOSE_PROFILES=
GENAI_SERVICE_AUTH_PRIVATE_KEY=
GENAI_SERVICE_AUTH_PUBLIC_KEY=
GENAI_SERVICE_AUTH_KEY_ID=
GCP_CREDENTIALS_PATH=./secrets/gcp-service-account.json
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=australia-southeast1
GEMINI_MODEL=
