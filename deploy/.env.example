# Image coordinates. CI replaces tags with immutable commit SHAs.
BACKEND_IMAGE_REGISTRY=ghcr.io/zhifeimi
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE=ghcr.io/zhifeimi/dentistdss-pwa
FRONTEND_IMAGE_TAG=latest

# Bind only to loopback when an existing reverse proxy or Cloudflare Tunnel
# runs on this host. Use 0.0.0.0 only for direct LAN access.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8080
PUBLIC_BASE_URL=https://dentist.example.com

# Generate independent, URL-safe values; do not reuse these examples.
POSTGRES_PASSWORD=replace-with-a-long-random-value
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-different-long-random-value
SPRING_CONFIG_USER=config-client
SPRING_CONFIG_PASS=replace-with-a-different-long-random-value

# PKCS#8 private key and X.509 public key, each as a single Base64 line.
JWT_RSA_PRIVATE_KEY=replace-with-base64-pkcs8-private-key
JWT_RSA_PUBLIC_KEY=replace-with-base64-x509-public-key
JWT_RSA_KEY_ID=dentistdss-homelab-1

# Google OAuth application.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# SMTP provider.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-user
MAIL_PASSWORD=replace-with-smtp-password

# Optional AI profile. Leave COMPOSE_PROFILES empty to deploy the core system
# without genai-service. To enable it, set COMPOSE_PROFILES=ai and provide a
# service-account JSON file at GCP_CREDENTIALS_PATH.
COMPOSE_PROFILES=
GCP_CREDENTIALS_PATH=./secrets/gcp-service-account.json
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=australia-southeast1
GEMINI_MODEL=
